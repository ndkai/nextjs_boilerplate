# ============================================================
#  Environment variables — EXAMPLE (NO secrets)
#  Copy to .env.local (project root) for local development:
#      cp env/example.env .env.local
# ============================================================

# Upstream SCA API. All /api/* requests are proxied here by the
# rewrite in next.config.ts (destination: ${API_UPSTREAM}/api/:path*).
# Value must have NO trailing slash and NO /api suffix.
#
#   UAT  : https://sca-api-uat.concung.vn
#   Beta : https://sca-api-uat.concung.vn   (same upstream as UAT)
#   Prod : https://sca-api.concung.com
API_UPSTREAM=

# Client-side API base URL (build-time inlined, NEXT_PUBLIC_*).
# LEAVE EMPTY to route browser calls through the relative `/api/*`
# server proxy above — required so a SINGLE build can be promoted
# across uat/beta/production. Only set this if you must call the
# backend directly from the browser (bypasses proxy, frozen at build).
NEXT_PUBLIC_API_BASE_URL=

# ------------------------------------------------------------
#  Multi-environment model (uat / beta / production)
# ------------------------------------------------------------
#  Per-env values live in committed files (NO secrets):
#    env/uat.env         -> npm run dev:uat   / build:uat   / start:uat
#    env/beta.env        -> npm run dev:beta  / build:beta  / start:beta
#    env/production.env  -> npm run dev:prod  / build:prod  / start:prod
#
#  Scripts load the file via scripts/with-env.mjs (process.loadEnvFile),
#  so the value in process.env wins over anything Next auto-loads.
#
#  Real secrets: inject as real environment variables in CI/deploy,
#  or use a gitignored env/<env>.local.env (see .gitignore).
#
#  output: "standalone" alternative — build ONCE, switch at runtime:
#    API_UPSTREAM=https://sca-api.concung.com node .next/standalone/server.js
# ------------------------------------------------------------
